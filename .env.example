# Copy this file to .env for local use. Never commit real credentials.

# Keep disabled unless you intentionally want live Quickbase integration tests.
QUICKBASE_RUN_INTEGRATION_TESTS=0

# Quickbase authentication.
QUICKBASE_REALM=example.quickbase.com
QUICKBASE_USER_TOKEN=qb-user-token

# Optional integration-test targets.
QUICKBASE_TEST_APP_ID=bp123456
QUICKBASE_TEST_TABLE_ID=bq123456

# Optional integration query controls.
QUICKBASE_TEST_QUERY={3.GT.0}
QUICKBASE_TEST_SELECT=3,6,7
